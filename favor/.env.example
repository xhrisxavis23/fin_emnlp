# FaVOR — Environment template
# Copy to `.env` and fill in.  The pipeline auto-loads this file at startup
# (see `run/config.py:_load_env_from_dotenv`).

# ---- Required: LLM API key ----
OPENAI_API_KEY=sk-...

# ---- Optional: LLM endpoint override ----
# Used when routing through a proxy (e.g. LiteLLM for Claude / Gemini).
# Example: OPENAI_BASE_URL=http://localhost:4000
# OPENAI_BASE_URL=

# ---- Optional: trace verbosity ----
# Max chars per prompt/response persisted under runs/<id>/agents/.
# Empty = unlimited.  Use a number (e.g. 200000) to cap.
# FINAGENT_LLM_TRACE_MAX_CHARS=
